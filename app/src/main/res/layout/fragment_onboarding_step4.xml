<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_dark_card"
        app:cardCornerRadius="16dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Baru menggunakan Nakama?"
                android:textColor="@color/text_primary_dark"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"/>

            <Button
                android:id="@+id/btnStartFresh"
                style="@style/ButtonStyle.Nakama.Outline"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="Mulai dari awal"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/bg_dark_surface"
                android:layout_marginVertical="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Install ulang Nakama?"
                android:textColor="@color/text_primary_dark"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"/>

            <Button
                android:id="@+id/btnRestore"
                style="@style/ButtonStyle.Nakama.Outline"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="Pulihkan cadangan"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>